# --- DBAG AI Playground (required) ---
AI_PLAYGROUND_API_KEY=paste-your-key-here
AI_PLAYGROUND_BASE_URL=https://devportal.deutsche-boerse.de/api
AI_PLAYGROUND_VERIFY_SSL=false        # Zscaler-friendly; or a path to a CA bundle
AI_PLAYGROUND_TIMEOUT=60

# --- Firm runtime (optional) ---
IFA_PROFILE=balanced                  # budget | balanced | premium

# --- Web search wiring (see README "Web search") ---
# auto    = Claude uses its native tool (known-good); other models use the generic flag
# generic = ALL models use the generic flag (hypothesis A — confirm with the M0 probe)
# anthropic = always use the Anthropic web_search tool (Claude only)
IFA_WEBSEARCH_MODE=auto
# The top-level request key used by the generic path; change to match the captured
# DevPortal payload once confirmed (e.g. web_search or webSearch).
IFA_WEBSEARCH_FLAG=web_search

# --- Data sources ---
# Required by SEC EDGAR fair-access policy (use a real contact). Only needed at M1.5+.
SEC_USER_AGENT=investment-firm-agents your.email@example.com
# Optional, free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# --- Optional deeper cited web research (pay-as-you-go; leave blank to stay free) ---
PERPLEXITY_API_KEY=
# PERPLEXITY_PROXY=https://your-proxy-host:8080

# --- Alpha Vantage fundamentals (optional; free key, 25 calls/day) ---
# Get one at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# --- Reddit retail sentiment (optional; OAuth 'script' app, read-only) ---
# Create a 'script' app at https://www.reddit.com/prefs/apps (app-only/client-credentials).
# CLIENT_ID = the string under the app name; CLIENT_SECRET = the 'secret' field.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Reddit requires a unique, descriptive User-Agent, e.g. 'investment-firm-agents/0.1 by u/<username>'
REDDIT_USER_AGENT=investment-firm-agents/0.1 by u/your_username
